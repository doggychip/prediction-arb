# Kalshi (leave empty to use public-only mode)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Kalshi environment: "demo" or "prod"
KALSHI_ENV=demo

# Polymarket (leave empty for read-only market data)
POLYMARKET_PRIVATE_KEY=

# Discord webhook for alerts
DISCORD_WEBHOOK_URL=

# LLM match verification (supports any OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_VERIFY_ENABLED=true
LLM_VERIFY_BATCH_SIZE=10
